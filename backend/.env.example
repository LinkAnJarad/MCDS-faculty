# ─── Faculty DSS – Backend Environment ───────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Use postgresql+psycopg:// for psycopg v3 (required on Windows)
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/faculty_dss

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_vRKnwL3zMSk8ttrk9EVmltvOfNKBiLRqZGP0G3B1dN
# Format: https://<YOUR_CLERK_DOMAIN>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://outgoing-gobbler-70.clerk.accounts.dev/.well-known/jwks.json
# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
